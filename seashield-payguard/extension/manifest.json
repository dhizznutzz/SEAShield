{
  "manifest_version": 3,
  "name": "SeaShield — AI Payment Guard",
  "version": "0.1.0",
  "description": "Scans checkout & invoice pages, and warns you with an AI risk score before you authorise a payment.",
  "permissions": ["storage", "activeTab", "scripting"],
  "host_permissions": [
    "http://localhost:3000/*",
    "https://*/*"
  ],
  "background": {
    "service_worker": "background/service-worker.js"
  },
  "action": {
    "default_popup": "popup/popup.html",
    "default_title": "SeaShield"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content/overlay.js", "content/detector.js"],
      "run_at": "document_idle",
      "all_frames": false
    }
  ]
}
